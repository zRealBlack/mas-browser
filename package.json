{
  "name": "mas-browser",
  "version": "1.3.8",
  "description": "MAS Browser — A modern, fast, and beautiful browser for everyone.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "publish": "electron-builder --win -p always",
    "publish:mac": "electron-builder --mac -p always"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.mas.browser",
    "productName": "MAS Browser",
    "copyright": "Copyright © 2026 yasso",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "logo.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "logo.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "MAS Browser"
    },
    "publish": {
      "provider": "github",
      "owner": "zRealBlack",
      "repo": "mas-browser",
      "releaseType": "release"
    }
  }
}